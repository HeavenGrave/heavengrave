<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="web.sn.dream.mapper.TransactionMapper">
    <insert id="insertTransaction">
        INSERT INTO transaction (id,type,classified,account,amount,des,budget,target,create_time,tally_book_id)
        VALUES
            (#{id},#{type},#{classified},#{account},#{amount},#{des},#{budget},#{target},#{createTime},#{tallyBookId})
    </insert>
    <delete id="deleteTransactionById">
        DELETE FROM transaction WHERE id=#{id}
    </delete>
    <update id="updateTransaction">
        UPDATE transaction set name=#{name},type= #{type},amount=#{amount} where id=#{id}
    </update>
    <select id="findTransactionByTallyBookId" resultType="web.sn.dream.pojo.Transaction">
        select  * from transaction where tally_book_id=#{tallyBookId}
    </select>
    <select id="findAllTransaction" resultType="web.sn.dream.pojo.Transaction">
        select * from transaction
    </select>
    <select id="findTransactionsByCond" resultType="web.sn.dream.pojo.Transaction">
        SELECT *
        FROM transaction
        WHERE 1=1
        <if test="tallyBookId != null">
            AND tally_book_id = #{tallyBookId}
        </if>
        <if test="type != null and type != ''">
            AND type = #{type}
        </if>
        <if test="classified != null and classified != ''">
            AND classified = #{classified}
        </if>
        <if test="startTime != null and startTime != ''">
            AND create_time &gt;= #{startTime}
        </if>
        <if test="endTime != null and endTime != ''">
            AND create_time &lt;= #{endTime}
        </if>
    </select>
</mapper>